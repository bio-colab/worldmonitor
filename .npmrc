registry=https://registry.npmjs.org/
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
# تقليل مشاكل الصلاحيات في ويندوز
fund=false
audit=false
# World Monitor npm defaults for restricted/corporate networks.
# Keeps installs resilient under intermittent 403/timeout/proxy environments.
registry=https://registry.npmjs.org/
strict-ssl=true
fund=false
audit=false
prefer-online=true
fetch-retries=5
fetch-retry-factor=2
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
# Set these per-machine if needed (do not commit credentials):
# proxy=http://proxy.example:8080
# https-proxy=http://proxy.example:8080
# noproxy=localhost,127.0.0.1
